# Set the default behavior for all files
* text=auto

# Explicitly set text files to be normalized
*.py text
*.txt text
*.md text
*.rst text
*.json text
*.yaml text
*.yml text
*.ini text
*.cfg text
*.env text
*.sh text eol=lf

# Set binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary

# Python specific
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Documentation
*.md text eol=lf

# Configuration files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Database files
*.sql text eol=lf